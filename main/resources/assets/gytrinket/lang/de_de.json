  "tooltip.gytrinket.shield_type.siphon": "Siphon",
  "tooltip.gytrinket.shield_type.none_desc": "Kann zusätzlich Eigenschaften des gleichen Schildtyps stapeln",
  "tooltip.gytrinket.shield_type.aura_desc": "Verbrennt nahegelegene Feinde und zündet sie an. (Wenn kein Anzündschaden angegeben, Standard ist %.1f/s Schaden für %d Sekunden)",
  "tooltip.gytrinket.shield_type.reflect_desc": "Reflektiert Projektile, die dich treffen. Reflektierte Projektile erhöhen Geschwindigkeit um %d%%, Schaden wird vom Schildeffekt beeinflusst",
  "tooltip.gytrinket.shield_type.amplification_desc": "Erhöht Angriffsschaden um %d%%. Verstärkung steigt, wenn Feinde in der Nähe sind. Maximum bei %d%%. Schildeffekt liefert sowohl Basiswert als auch Maximum. Gewährt %d%% Bewegungsgeschwindigkeit, wenn das Schild aktiv ist (beeinflusst vom Schildeffekt)",
  "tooltip.gytrinket.shield_type.warp_desc": "Wenn das Schild bricht, Teleportation in Blickrichtung. Explosionen am Start- und Endpunkt des Teleports verursachen %.1f Explosionsschaden",
  "tooltip.gytrinket.shield_type.siphon_desc": "Alle %d Ticks verursacht %.1f Schaden bei nahegelegenen Feinden und stellt %d%% des verursachten Schadens als Schild wieder her. (Schaden wird gleichmäßig auf Feinde verteilt) Kontinuierliches Siphonieren erhöht Schildeffekt und Schildeffektradius, bis zu %d%%. Zerfällt schnell, wenn keine Ziele vorhanden sind.",

  "tooltip.gytrinket.adaptive_armor_enabled": "Adaptive Rüstung aktiviert",
  "tooltip.gytrinket.adaptive_armor_effect": "Schadennehmen erzeugt Rüstungsstapel. Jeder Rüstungsstapel gewährt Schadensreduktion",
  "tooltip.gytrinket.adaptive_armor_bond": "Bindung",
  "tooltip.gytrinket.adaptive_armor_bond_effect": "Rüstungsstapel gewähren zusätzlich Schildeffekt und Erholungseffizienz",

  "tooltip.gytrinket.electric_discharge": "Elektrische Entladung",
  "tooltip.gytrinket.electric_discharge_effect": "Spielerangriffe erzeugen elektrische Lichtbögen, die nahegelegene Feinde verbrennen. Langsamere Angriffsgeschwindigkeit bedeutet längere Lichtbögen und höheren Schaden",

  "tooltip.gytrinket.efficiency": "Effizienz",
  "tooltip.gytrinket.efficiency_effect": "Wenn der Spieler nicht im Angriffs-Cooldown ist, gewährt %s%% unabhängiger Multiplikator Schild-Abklingzeitreduktion und Erholungseffizienz",

  "tooltip.gytrinket.barrier_effect": "Wenn das Schild Schaden über %d Punkte nimmt, wird der Schaden auf %d begrenzt",

  "tooltip.gytrinket.regen_shield": "Regenerierendes Schild",
  "tooltip.gytrinket.regen_shield_effect": "Aktiviert natürliche Schilderholung. Wenn das Schild einen Wert hat, beträgt die Gesundheitsregeneration des Spielers %d%%, die Schildregeneration %d%%. Wenn das Schild keinen Wert hat, beträgt die Regeneration 100%%",

  "tooltip.gytrinket.reflect_damage": "Reflexions-Schild",
  "tooltip.gytrinket.reflect_damage_effect": "Wenn das Schild Schaden nimmt, werden brennende Partikel auf den Angreifer abgefeuert. Verbrennt und zündet Feinde an",

  "tooltip.gytrinket.explosive_shield": "Explosiv-Schild",
  "tooltip.gytrinket.explosive_shield_effect": "Wenn das Schild bricht, verursacht es %.1f Explosionsschaden bei nahegelegenen Feinden",

  "tooltip.gytrinket.shield_transfer": "Schildtransfer",
  "tooltip.gytrinket.shield_transfer_effect": "Das Schild schützt dich nicht mehr, sondern schützt deine Konstrukte (du kannst Schildempfänger verwenden, um zusätzlich andere Entitäten zu schützen). Jede geschützte Entität reduziert Schildeffekt und Schildeffektradius um %.1f%%",

  "tooltip.gytrinket.binary_protocol": "Binärprotokoll",
  "tooltip.gytrinket.binary_protocol_effect": "Wenn das Schild Schaden nimmt, nimmt der Spieler %d%% des Schadens für das Schild (oder umgekehrt)",

  "tooltip.gytrinket.weaponized_shield": "Waffenschild",
  "tooltip.gytrinket.weaponized_shield_effect": "Während das Schild aktiv ist, wende %d%% Verwundbarkeit auf nahegelegene Feinde an (beeinflusst vom Schildeffekt-Attribut)",

  "tooltip.gytrinket.near_death_protection": "Todesnaher Schutz",
  "tooltip.gytrinket.near_death_protection_effect": "Wenn eine Drohne kurz vor dem Tod steht, wird der Tod verhindert, 1 Gesundheit wiederhergestellt und Unverwundbarkeit für %.1f Sekunden gewährt. Abklingzeit: %.1f Sekunden (pro Drohne)",

  "tooltip.gytrinket.near_death_explosion": "Todesnahe Explosion",
  "tooltip.gytrinket.near_death_explosion_effect": "Wenn eine Drohne kurz vor dem Tod steht, wird der Tod verhindert, 1 Gesundheit wiederhergestellt und Unverwundbarkeit für %.1f Sekunden gewährt. Verlässt die Formation und stürmt auf Feinde zu zur Selbstzerstörung (Schaden = Max. Gesundheit × Geschwindigkeit × %.1f, Radius %.1f Blöcke). Erzwungene Selbstzerstörung beim Ende der Unverwundbarkeit",

  "tooltip.gytrinket.pursuit_array": "Verfolgungs-Array",
  "tooltip.gytrinket.pursuit_array_effect": "Rüstet Drohnen zu Sturm-Drohnen auf und schaltet das Verfolgungs-Array frei (Tab drücken zum Wechseln). Drohnen im Verfolgungs-Array haben erhöhte Angriffsgeschwindigkeit",

  "tooltip.gytrinket.formation_array": "Formations-Array",
  "tooltip.gytrinket.formation_array_effect": "Schaltet das Formations-Array frei. Drohnen im Formations-Array haben erhöhten Schaden, verringerte Angriffsgeschwindigkeit und wechseln zu Strahlkanonen-Angriffen",

  "tooltip.gytrinket.commander": "Kommandant",
  "tooltip.gytrinket.commander_effect": "Ernennt automatisch die gesündeste Drohne zum Kommandanten (max. %d). Ernennungsverzögerung: %.1f Sekunden. Kommandanten erhalten Bonus-Gesundheit und -Schaden",

  "tooltip.gytrinket.guard_array": "Wach-Array",
  "tooltip.gytrinket.guard_array_effect": "Schaltet das Wach-Array frei. Verteidigungs-Drohnen im Wach-Array konzentrieren sich zwischen dem Spieler und dem nächsten Feind, um Angriffe abzufangen",

  "tooltip.gytrinket.arc_barrier": "Lichtbogen-Barriere",
  "tooltip.gytrinket.arc_barrier_effect": "Wenn sich eine Verteidigungs-Drohne zwischen dem Spieler und der Schadensquelle befindet, fängt die Drohne den Schaden ab. Positionstoleranz: %.1f Blöcke",

  "tooltip.gytrinket.reshaping": "Umformung",
  "tooltip.gytrinket.reshaping_effect": "Verteidigungs-Drohnen regenerieren %.1f%% Max.-Gesundheit pro Sekunde. Verteidigungs-Drohnen erzeugen beim Tod Rüstungssplitter. Aufnahme von Rüstungssplittern gewährt %.1f%% Schadensreduktion für %.1f Sekunden",

  "tooltip.gytrinket.counter_pulse": "Gegenimpuls",
  "tooltip.gytrinket.counter_pulse_effect": "Verteidigungs-Drohnen lösen alle %.1f Sekunden einen Gegenimpuls aus, der %.1f Explosionsschaden an Feinden innerhalb von %.1f Blöcken verursacht. Lädt sich auf, wenn nicht ausgelöst (alle %d Ticks, max. %d Stapel). Wird bei Schaden sofort ausgelöst, ohne Abklingzeit",

  "tooltip.gytrinket.precision_construct": "Präzisions-Konstrukt",
  "tooltip.gytrinket.precision_construct_effect": "Jedes Spieler-Level gewährt %.2f%% unabhängiger Multiplikator Konstrukt-Baugeschwindigkeit",

  "tooltip.gytrinket.advanced_engineering": "Fortschrittliches Ingenieurwesen",
  "tooltip.gytrinket.advanced_engineering_effect": "Jedes Spieler-Level gewährt %.1f%% unabhängiger Multiplikator Drohnen-Gesundheit und Drohnen-Schaden",

  "tooltip.gytrinket.assault": "Sturmangriff",
  "tooltip.gytrinket.assault_effect": "Linksklick halten für Auto-Angriff. Angriffsgeschwindigkeit steigt allmählich. Nimmt Eigenschaden (steigt mit Angriffsgeschwindigkeit). -60% Bewegungsgeschwindigkeit während des Sturmangriffs",
  "tooltip.gytrinket.charged_attack": "Aufgeladener Angriff",
  "tooltip.gytrinket.charged_attack_effect": "Linksklick halten zum Aufladen, loslassen zum Angreifen. Aufladung hat kein Limit, wird aber durch Abzug begrenzt. Schaden = aktueller Schaden + Aufladewert. -20% Bewegungsgeschwindigkeit beim Aufladen",
  "tooltip.gytrinket.charged_shield": "Aufgeladenes Schild",
  "tooltip.gytrinket.charged_shield_effect": "Beim Aufladen dynamischer Schildeffekt- und Radiusbonus (%s%% der Aufladung, max. %s%%). Fällt nach dem Loslassen schnell ab. Zusätzlich -15% Bewegungsgeschwindigkeit beim Aufladen",
  "tooltip.gytrinket.grudge": "Groll",
  "tooltip.gytrinket.grudge_effect": "Beim Aufladen gewährt jeder verlorene Gesundheits- oder Schildpunkt %s Aufladerate. Zerfällt immer (%s + %s%% des aktuellen Werts pro Tick). Wird beim Loslassen zurückgesetzt. Zusätzlich -15% Bewegungsgeschwindigkeit beim Aufladen",

